<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍽️"
                android:textSize="40sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mood Food Finder"
                android:textColor="@color/text_dark"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select your mood and preferences"
                android:textColor="@color/text_medium"
                android:textSize="14sp"
                android:layout_marginTop="4dp"/>

            <!-- Info button -->
            <ImageButton
                android:id="@+id/btnInfo"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/btn_reset_bg"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#C084FC"
                android:contentDescription="Info"/>
        </LinearLayout>

        <!-- Display Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/card_white"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:id="@+id/displayInner"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_display_card"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvFoodEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🍔"
                        android:textSize="56sp"/>

                    <TextView
                        android:id="@+id/tvDisplayText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your food suggestion will appear here"
                        android:textColor="@color/text_medium"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Mood Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="@color/card_white"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="How are you feeling?"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/btnLazy"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_lazy"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😴" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lazy" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnSad"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_sad"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😢" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sad" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnGrumpy"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_grumpy"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😠" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Grumpy" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/btnStressed"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_stressed"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😰" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stressed" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnAdventurous"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_adventurous"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🤩" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Adventurous" android:textColor="@color/text_dark" android:textSize="11sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnSelfCare"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_selfcare"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🧘" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Self-care" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnSophisticated"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_sophisticated"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎩" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sophisticated" android:textColor="@color/text_dark" android:textSize="11sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnAggressive"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_aggressive"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💢" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Aggressive" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnBurnedOut"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/mood_bg_burnedout"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🪫" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Burned out" android:textColor="@color/text_dark" android:textSize="13sp" android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Condition Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/card_white"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Add filters (optional)"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Condition Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/btnQuick"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:layout_marginEnd="10dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/condition_btn_default"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ " android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quick" android:textColor="@color/text_dark" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnBudget"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:layout_marginEnd="10dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/condition_btn_default"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰 " android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Budget" android:textColor="@color/text_dark" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnSnack"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/condition_btn_default"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🍿 " android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Snack" android:textColor="@color/text_dark" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Condition Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnHealthy"
                        android:layout_width="wrap_content"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/condition_btn_default"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥗 " android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Healthy" android:textColor="@color/text_dark" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bottom Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="Reset"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:background="@drawable/btn_reset_bg"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnCalculate"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="2"
                android:text="Get Food Suggestion"
                android:textColor="@color/text_white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="@drawable/btn_suggest_gradient"
                android:stateListAnimator="@null"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>